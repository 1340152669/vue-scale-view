{
  "name": "vue-scale-view",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Vue 3 viewport scale container — scales children to fill the screen without black bars (cover mode). With min-width/min-height guard. Ideal for large-screen dashboards and data visualization.",
  "keywords": [
    "vue",
    "vue3",
    "scale",
    "container",
    "dashboard",
    "fullscreen",
    "adaptive",
    "responsive",
    "cover",
    "large-screen",
    "data-v",
    "datav",
    "visualization",
    "component",
    "resize",
    "transform"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "bugs": "",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/scale-view.umd.cjs",
  "module": "./dist/scale-view.js",
  "types": "./dist/index.d.ts",
  "style": "dist/vue-scale-view.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/scale-view.js",
      "require": "./dist/scale-view.umd.cjs"
    },
    "./dist/vue-scale-view.css": "./dist/vue-scale-view.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --project tsconfig.build.json --declaration --emitDeclarationOnly",
    "prepublishOnly": "npm run build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "~5.8.0",
    "vite": "^6.3.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.0.0"
  }
}
